     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["In view of the interest and conflicts in the results"
		,"of experiments at energies near 9.5 MeV, the data"
		,"from Subent 003 at 9.48 MeV were revised. Primarily"
		,"corrections of the order of 6% occurred at forward"
		,"angles where an error had been made in correcting for"
		,"multiple scattering in absorbers placed over the"
		,"plates. In addition, a more accurate center-of-mass"
		,"transformation and the latest values of the physical"
		,"constants were used in evaluating the results."]
	}
      ]
