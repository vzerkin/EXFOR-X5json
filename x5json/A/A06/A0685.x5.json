	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"SIBAR", "dict":"DETECTOR", "idict":22,"hlp":"Silicon surface barrier detector"}]
	,"x4freetext":["  A thin, 20- or 25- micrometers - thick silicon"
		,"detector measuring the backward scattering.  The choice"
		,"of the thickness of the backward detector was such as"
		,"to allow light particles, like alphas from breakup"
		,"transfer and other contaminant reactions (7Li+12C), to"
		,"go through while Li particles stop in the detector."]
	}
