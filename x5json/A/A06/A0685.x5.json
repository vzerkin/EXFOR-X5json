     ,"ADD-RES":[
	{"x4pointer":" "
	,"x4codes":[{"code":"THEO", "dict":"ADD-RES", "idict":20,"hlp":"Theory"}
	    ,{"code":"POT", "dict":"ADD-RES", "idict":20,"hlp":"Parameters of nuclear potential"}]
	,"x4freetext":[" The results were analyzed in a"
		,"double-folding model by using the BDM3Y1 interaction."
		,"Previous data of 6Li+28Si, 6,7Li +138Ba, and"
		,"6,7Li+208Pb were also considered in the same"
		,"theoretical framework, in order to draw meaningful"
		,"comparisons.  An anomalous behavior for both the real"
		,"and imaginary part of the optical potential develops"
		,"for the weakly bound nuclei 6,7Li in the vicinity of"
		,"the barrier, which in total contradicts the"
		,"conventional threshold anomaly applied to stable"
		,"systems.  This behavior may be described only"
		,"qualitatively by dispersion relations."]
	}
      ]
