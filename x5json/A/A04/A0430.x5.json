     ,"INC-SOURCE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["To increase the beam current the analyzing magnet was"
		,"tuned to select different beams: 1H+, 2H+ and"
		,"3H+. In fact the extraction efficiency turned out"
		,"to be higher for the molecular beams 1H+ and 3H+."]
	}
