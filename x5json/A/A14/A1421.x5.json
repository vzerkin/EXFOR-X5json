	 ,"x4codes":[{"code":"SCIN", "dict":"DETECTOR", "idict":22,"hlp":"Scintillation detector"}]
	,"x4freetext":[" 12.7 cm diam. by 5.08 cm thick Pilot B"
		,"scintillator. Relative efficiency of the neutron"
		,"detector was measured by 7Li(p,n)7Be (gr.state)"
		,"reaction. The absolute efficiency for identical"
		,"detector was measured at Los Alamos and was found"
		,"0.35+-0.03 for 1.8 MeV."]
