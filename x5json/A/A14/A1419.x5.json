	}
      ]
     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The experimental angular distributions were analysed"
		,"by least-squares fitting of Legendre polynomial"
		,"expansions to the experimental points. Theoretical"
		,"angular distributions are given by"
		,"w(theta)=a0*(1+a1*p1(cos(theta))+a2*p2(cos(theta))+"
		,"      a3*p3(cos(theta))+...)"]
	}
      ]
