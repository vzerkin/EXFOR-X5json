     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["To analyse the spectra of residual activity and"
		," calculate the intensities of gamma quanta, an"
		," automatic system was used that provides data"
		," visualization, separation of overlapping maxima and"
		," their approximation by Gaussian curves using the"
		," least squares method with standard algorithms."
		,"Experimental cross sections per equivalent photon in"
		," photoproton and photoneutron reactions were"
		," obtained."
		,"Since a target of natural isotopic composition was"
		," used, all possible reactions were taken into account"
		," in the cross section per equivalent photon using"
		," formula (7) of the article."]
	}
      ]
