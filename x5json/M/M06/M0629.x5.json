	{"x4pointer":" "
	 ,"x4codes":[{"code":"AREA", "dict":"ANALYSIS", "idict":23,"hlp":"Area analysis"}]
	,"x4freetext":[" Isomer yield and ratio  measurement  using  the"
		," g-quanta energy spectrum lines data  separated  using"
		," the code  ACTIV.  The  integral  cross  sections were"
		," obtained  using  the  measured  isomeric  ratios  and"
		," published  total  photoneutron reaction cross section"
		," data."]
	}
