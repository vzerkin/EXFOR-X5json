	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["HIgS provided quasi-monoenergetic, linearly polarized"
		,"gamma-ray beams at 16 energy settings between 3.10"
		,"and 5.44 MeV with a relative full width at half-"
		,"maximum (FWHM) of about 3%."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"HPGE", "dict":"DETECTOR", "idict":22,"hlp":"Hyperpure (high purity) germanium detector"}]
	,"x4freetext":[" The gamma**3 setup at HIgS, consisting of six"
		,"high-purity germanium (HPGe) detectors placed at"
		,"angles suitable to distinguish between photons of"
		,"different multipole character, taking advantage of"
		,"the >99% linear polarization of the beam."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":{"Nucl":"32-GE-74","ENR":0.989}
	,"x4freetext":[" The 74Ge target consisted of"
		,"germanium dioxide powder, isotopically enriched to"
		,"98.90(5)%, weighing 8.968(5) g with a thickness of"
		,"1.91 cm."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"GSPEC", "dict":"METHOD", "idict":21,"hlp":"Gamma ray spectrometry"}]
	,"x4freetext":[" The target nuclei were excited by the HIgS"
		,"beam and the fluorescent radiation emitted was"
		,"measured. Data were accumulated for 4-6 h at each"
		,"lower energy setting and 6-7 h for each higher energy"
		,"one."]
	}
