     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}]
	,"x4freetext":[" To determine the resonance yield (Yres) six"
		,"measurements were carried out above the resonance"
		,"energy at Ep=427 or 433 keV, to obtain the total"
		,"yield (Ytot) and two measurements below the resonance"
		,"at Ep=396 and 404 keV to determine the yield"
		,"without the resonance region (Yoff)."
		,"The applied beam energies were in the range between"
		,"Ep=394-433 keV, below and above the resonance energy."
		,"The cyclic activation method was used, meaning the"
		,"irradiation and decay counting phases being repeated"
		,"many times. The duration of the irradiation in one"
		,"cycle was 5 min, followed by a 15 min beam-off period"
		,"for decay and gamma-counting."
		,"Thin Al layer was evaporated on the targets to drain"
		,"the electric charge deposited by the proton beam."
		,"The thickness of the Al layer was about 2 keV at"
		,"Ep=416.9 keV resonance energy."]
	}
      ]
