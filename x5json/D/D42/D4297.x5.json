     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["The targets were produced by evaporation of metallic,"
		,"highly enriched (93.1%) 113In, (142 microg/cm2) onto"
		,"thin carbon foil(~40 microg/cm2)."]
	}
	,{"x4pointer":" "
