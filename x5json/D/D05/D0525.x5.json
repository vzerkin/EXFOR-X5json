     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":{"Nucl":"62-SM-144","ENR":0.9652}
	,"x4freetext":[" 96.52+/-0.03%"
		,"A thin carbon foil (thickness 20 mg/cm2) was used as"
		," backing."
		,"During the experiment one enriched 144Sm and one"
		," natural Sm target, and one carbon backing without"
		," samarium layer were used."
		,"The thickness of the samarium targets was determined"
		," by the energy loss of the alfa-particles in the"
		," samarium layer."
		,"The resulting thicknesses are 142 ug/cm2 (144Sm) and"
		," 218 ug/cm2 (natural Sm) with uncertainties of about"
		," 10%."
		,"The pure carbon target was used also for the angular"
		," calibration."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	,"x4codes":[{"code":"SIBAR", "dict":"DETECTOR", "idict":22,"hlp":"Silicon surface barrier detector"}]
	,"x4freetext":[" four silicon surface-barrier detectors with an"
		," active area 50 mm2 and thicknesses between 300 um and"
		," 1500 um."]
	}
      ]
     ,"ERR-ANALYS":[
	{"x4pointer":" "
	,"x4code":{"header":"DATA-ERR"
	     ,"headerHelp":"Error in value of quantity, defined under ERR-ANALYS"}
	,"x4freetext":[" statistical uncertainties (<1% for almost"
		," any angle) and systematic uncertainties coming from"
		," the accuracy of the angular adjustment of the"
		," detectors and from contributions of other samarium"
		," isotopes in the 144Sm target (chemical impurities of"
		," the targets are negligible)."]
	}
