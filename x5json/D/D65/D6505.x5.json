     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":{"Nucl":"48-CD-108","ENR":0.663}
	,"x4freetext":[" Isotopically enriched 108Cd"
		," targets (38.7 mg) on Mylar (H8C10O4) backing were"
		," prepared using the vacuum evaporation technique."
		," Eight different targets with thicknesses ranging from"
		," 288 to 659 ug/cm2 were deposited on a 13 um Mylar"
		," backings."
		,"Aluminum foils (6.5 um, 12 um, 25 um and 100 um and"
		," 99.95% pure) were used as energy degraders to reduce"
		," the proton beam energy before and within the target"]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"HPGE", "dict":"DETECTOR", "idict":22,"hlp":"Hyperpure (high purity) germanium detector"}]
	,"x4freetext":[" detector with 40% relative efficiency and energy"
		," resolution of 1.8 keV at 1.33 MeV gamma-ray energy."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}
	    ,{"code":"BCINT", "dict":"METHOD", "idict":21,"hlp":"Beam current integrated"}]
	,"x4freetext":[" Targets were irradiated for 6-17 hrs with"
		," a proton beam of 150-200 nA."]
	}
      ]
