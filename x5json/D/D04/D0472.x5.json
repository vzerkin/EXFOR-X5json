     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["Commercially available helium gas, with nominal"
		,"purity of 99.9999%, was used in the experiment.The"
		,"elastic scattering measurement was performed at LNS"
		,"using the CT2000 scattering chamber having a"
		,"diameter of 2 m which was filled with helium gas at"
		,"a pressure of 428.3 mbar."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}
	    ,{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":["Two large dE-E silicon telescopes (65 mu-m"
		,"+500 mu-m thick) were placed in the forward part of the"
		,"chamber to detect and identify a-particles recoiling"
		,"in a finite angular range around 180 in the center"
		,"of mass (c.m.) system. A microchannel plate (MCP)"
		,"detector was mounted just before the entrance window"
		,"to measure the beam intensity, which was of the"
		,"order of 10**5 pps, and to produce a fast signal for"
		,"time of flight measurement."]
	}
      ]
     ,"ANALYSIS":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["The elastic scattering excitation function is"
		,"reconstructed from the measured energy spectra of"
		,"the recoiled a-particles by taking into consideration"
		,"the two-body kinematics and energy consideration losses"
		,"of 9Be in helium gas before the interaction and of"
		,"4He after the interaction."]
	}
      ]
