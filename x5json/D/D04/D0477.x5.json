     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["The 9.33 mg/cm2 thick (CH2)n target. A carbon foil"
		,"of 10.88 mg/cm2 in thickness was applied to"
		,"evaluating the background that arose from the carbon"
		,"atoms in the (CH2)n target."]
	}
      ]
     ,"INC-SOURCE":[
	{"x4pointer":" "
	,"x4codes":[{"code":"D-C12", "dict":"INC-SOURCE", "idict":19,"hlp":"12C(d,n)"}]
	,"x4freetext":[" The 13N secondary beam was produced via the"
		,"reaction 2H(12C,13N)n. A 100- to 150-pnA 12C beam of"
		,"72 MeV was used to bombard a 4.8-cm-long deuterium"
		,"gas cell at a pressure of about 1.5 atm. The front"
		,"and rear windows of the gas cell were Havar foils of"
		,"1.9 mg/cm2 in thickness."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	,"x4codes":[{"code":"SISD", "dict":"DETECTOR", "idict":22,"hlp":"Silicon strip detector"}]
	,"x4freetext":[" dE-E telescope consisting of a 63-mu-m-thick"
		,"Double-Sided Silicon Strip Detector (DSSSD) and a"
		,"982-mu-m-thick quadrant silicon detector (MSQ). Both"
		,"detectors are 50 x 50 mm2 in size."]
	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":[" The secondary beam was analyzed by a 13.2-mu-m-"
		,"thick silicon dE detector. The output of this dE"
		,"detector was taken into spectra by a multichannel"
		,"analyzer to monitor the purity of 13N and was"
		,"recorded by a scaler for beam normalization."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}]
	}
      ]
     ,"ERR-ANALYS":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["The systematical errors including the uncertainties in"
		,"the detector solid angle and beam normalization are"
		,"small compared with the statistical ones."]
	}
	,{"x4pointer":" "
