     ,"ANALYSIS":[
	{"x4pointer":" "
	,"x4codes":[{"code":"WSP", "dict":"ANALYSIS", "idict":23,"hlp":"Woods-Saxon potential"}]
	,"x4freetext":["Optical model analysis was carried out using"
		,"three different model potentials using parametric"
		,"Woods-Saxon and folded M3Y forms, forms for both the"
		,"real and imaginary potentials."]
	}
