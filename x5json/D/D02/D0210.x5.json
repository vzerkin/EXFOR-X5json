     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Two different targets were used with thicknesses of"
		," 50 and 320 mg/cm2, respectively. The target material"
		," was calcium of natural composition, i.e. 97 % of 40Ca."
		," The targets were strip-shaped, 3 mm wide, i.e. of the"
		," same width as the beam spot, to get better localized"
		," scattering."]
	}
      ]
