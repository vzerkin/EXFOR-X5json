	,"x4freetext":[" Two silicon detectors were placed ~100 mm"
		,"from the target center at a 15.5 degree angle to the"
		,"beam inside the scattering chamber. They monitored"
		,"the beam and normalized ER cross-sections using"
		,"elastic yields with a 1 mm collimator."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"MAGSP", "dict":"DETECTOR", "idict":22,"hlp":"Magnetic spectrometer"}
	    ,{"code":"MWPC", "dict":"DETECTOR", "idict":22,"hlp":"Multi-wire proportional counter"}]
	,"x4freetext":[" A position-sensitive MWPC (150 mm X 50 mm)"
		,"filled with 3.0 mbar isobutane was used at the"
		,"Heavy Ion Reaction Analyser focal plane to detect"
		,"heavy evaporation residues."]
	}
      ]
