     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["Self supporting target of 64Ni, prepared by electron"
		,"beam evaporation from 99% enriched metallic powder."
		,"The thickness of the target was 376 ug/cm2."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"SIBAR", "dict":"DETECTOR", "idict":22,"hlp":"Silicon surface barrier detector"}
	    ,{"code":"SIBAR", "dict":"DETECTOR", "idict":22,"hlp":"Silicon surface barrier detector"}]
	,"x4freetext":[" The outgoing particles were"
		,"detected by four dE-E telescopes with silicon surface"
		,"barrier detectors placed on rotatable arm at an"
		,"angular separation of 10 degrees. Two of the"
		,"telescopes with 15 um, 25 um thick delta E detectors"
		,"and 500 um, 3 mm thick E detectors were set to detect"
		,"the scattered particles at forward angles and"
		,"similar set of two telescopes was placed at backward"
		,"angles. The solid angles subtended by the telescopes"
		,"at the target center were 0.097, 0.081, 0.186 and"
		,"0.144 msr, respectively."]
	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"SIBAR", "dict":"DETECTOR", "idict":22,"hlp":"Silicon surface barrier detector"}]
	,"x4freetext":[" Two monitor detectors of thickness 2 mm and 3"
		,"mm fitted with 1 mm phi Tantalum collimators were"
		,"mounted at +- 15 degrees about the beam axis and at a"
		,"distance of 40.7 cm from the target center."]
	}
      ]
