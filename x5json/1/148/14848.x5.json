     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"TOF", "dict":"METHOD", "idict":21,"hlp":"Time-of-flight"}]
	,"x4freetext":[" 80 m flight path. The boron and blank"
		," (including tantalum end caps) samples were measured"
		,"at approximately 10 minute intervals. Typical"
		,"measurements lasted several days. Two separate beam"
		,"monitors were employed for fluence normalization."
		,"These data have been grouped in ~5% energy groups."]
	}
      ]
     ,"CORRECTION":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The maximum dead time correction was approximately"
		,"60% for the 80 m measurements due to a longer data"
		,"gate in the acquisition system. Because of this large"
		,"correction at 80 m, additional measurements using"
		,"thick iron filters in the beam were done at this"
		,"distance. The maximum dead time correction was"
		,"reduced to less than 0.3%, although only"
		,"approximately 20 neutron energy windows between 20"
		,"and 600 keV were available for analysis."]
	}
      ]
