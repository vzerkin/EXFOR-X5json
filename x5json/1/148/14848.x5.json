     ,"INC-SPECT":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The energy region extended from about 0.1 to 20 MeV"
		,"using 80 m & 200 m flight paths and 10 ns electron beam"
		,"width. The 2.3 cm diameter neutron beam was"
		,"collimated to originate from tantalum portion of the"
		,"target in order to reduce the gamma ray background"
		,"produced in the water moderator."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SCIN", "dict":"DETECTOR", "idict":22,"hlp":"Scintillation detector"}]
	,"x4freetext":[" The neutron detector consisted of a 2.5 cm"
		,"thick NE110 plastic scintillator."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Two samples were contained in 3.2"
		,"cm diameter cylindrical holders with 0.5 cm thick"
		,"tantalum end caps. The thickness in each sample of"
		,"10B (0.2355 and 0.2349 atoms per barn)"
		,"was determined"
		,"from the dimensions of the precisely matched holder,"
		,"the chemical analysis of the boron, and the weight of"
		,"the material."]
	}
      ]
