     ,"FACILITY":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"REAC", "dict":"FACILITY", "idict":18,"hlp":"Reactor"}
	    ,{"code":"1USAMIS", "dict":"INSTITUTE", "idict":3,"hlp":"University of Missouri, Columbia, MO, United States of America"}]
	,"x4freetext":[" The University of Missouri Research"
		,"Reactor (MURR)."]
	}
      ]
     ,"INC-SPECT":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The thermal and resonance region fluxes were"
		,"determined to be (9.4+-0.6)*10**13 and (6.4+-0.9)"
		,"*10**12 neutrons/cm2/s, respectively. The uncertainty"
		,"on the thermal and resonance region fluxes includes"
		,"the uncertainties in the literature cross section"
		,"values (~2-5%) in addition to statistical and"
		,"systematic counting uncertainties (~3%) and"
		,"uncertainty in the foil masses (~2%). While the"
		,"results from the different foil monitors yielded"
		,"consistent values, their standard deviation was also"
		,"included as an uncertainty; in total, when added in"
		,"quadrature, this led to overall uncertainties of 6.2%"
		,"for the thermal flux and 14.5% for the resonance flux."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"HPGE", "dict":"DETECTOR", "idict":22,"hlp":"Hyperpure (high purity) germanium detector"}]
	,"x4freetext":[" a Low-Energy Photon Spectrometer (LEPS)"
		,"detector and two p-type coaxial high purity germanium"
		,"detectors (HPGe) detectors."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["It was produced via proton irradiation of germanium"
		,"and was allowed to decay for ~1 year following"
		,"irradiation to eliminate impurities from other"
		,"arsenic radioisotopes, which all have half-lives"
		,"shorter than 20 d. After the decay period, no"
		,"activity was detectable other than 73As. Two samples"
		,"of 73As were prepared for irradiation. For each"
		,"sample, a small amount of solution (<200 microL of"
		,"0.01 M HNO3) containing the activity was added to the"
		,"bottom of a quartz tube with an inner diameter of 6 mm,"
		," an outer diameter of 8 mm, and a length of ~40 mm. The"
		," 73As samples were characterized with gamma-ray"
		,"spectroscopy to assess their initial activity. Each"
		,"sample contained ~240 microCi 73As (~8*10**13 atoms)"
		,"prior to irradiation."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}]
	,"x4freetext":[" The 73As samples and flux monitors (Zr, Mo,"
		,"and Fe foils) were shipped to MURR and were"
		,"irradiated in the reactor for 126.72 h. All the"
		,"samples were colocated in one irradiation canister to"
		,"minimize any neutron-flux differences they"
		,"experienced. The samples were shipped back to LLNL"
		,"two days after the end of irradiation and were"
		,"subsequently counted via gamma-ray spectroscopy at"
		,"the NCF to assess the activity levels of the"
		,"radionuclides of interest. The two 73As samples were"
		,"counted multiple times with the three detectors over"
		,"periods ranging from 0.5 to 48 h. The 73As sample was"
		,"counted before and after irradiation to determine the"
		,"number of 73As atoms initially and the number of 73As"
		,"and 74As atoms after irradiation. From these values,"
		,"along with the irradiation time and the fluxes"
		,"determined from monitor foils as described above, the"
		,"thermal neutron capture cross section was calculated."]
	}
      ]
     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["To account for potential contributions from the"
		,"resonance region cross section, the (n,gamma) thermal"
		,"cross section was calculated for two scenarios: one"
		,"where the thermal cross section, sigmath, was set"
		,"equal to the resonance region cross section, sigmarr,"
		," (i.e., sigmath = sigmarr), and another where"
		,"sigmarr = 0. The average of these two results is the"
		,"adopted cross section."]
	}
      ]
     ,"ERR-ANALYS":[
	{"x4pointer":" "
	 ,"x4code":{"header":"DATA-ERR"
	     ,"headerHelp":"Error in value of quantity, defined under ERR-ANALYS"}
	,"x4freetext":[" The uncertainties shown are from counting"
		,"statistics only. The additional uncertainties, which"
		,"are common to all the points, are included in the"
		,"calculations."]
	}
      ]
