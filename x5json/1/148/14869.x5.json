     ,"REFERENCE":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"J,PR/C,113,034322,2026","stdFileName":"J,PR_C,113,034322,2026"
		,"year":2026,"typ":"J","ref":"J,PR/C","vol":"113","p":"034322"
