     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The tungsten foils used were 10 mm x 10 mm in area"
		,"and 0.01 mm thick. They were sandwiched between two"
		,"Au monitor foils of the same area and 0.025 mm in"
		,"thickness."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}]
	,"x4freetext":[" The foil assembly was positioned at a"
		,"distance of 1.2 cm from the end of the neutron"
		,"production targets at 0 degree. Irradiation times"
		,"varied between 2 and 12 h, depending on the neutron"
		,"source reaction and the deuteron energy. Neutron flux"
		,"was obtained from the measured 196Au activity"
		," (total yield in the photopeak) and the cross-section"
		,"values for the 197Au(n,2n)196Au monitor reaction."
		,"The Au foils were counted independently from the W"
		,"foils."]
	}
      ]
