     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"LONGC", "dict":"DETECTOR", "idict":22,"hlp":"Long counter"}]
	,"x4freetext":[" A \"long counter\" has been used to measure the"
		,"fast neutron flux along the centerline of the source"
		,"coil in air. The \"long counter\" measures fast"
		,"neutron flux independent of the neutron energy"
		,"between 0.5 Mev and 3.0 Mev. This detector has been"
		,"calibrated with a Ra-Be and a Po-Be neutron source"
		,"of known source strengths."]
	}
      ]
