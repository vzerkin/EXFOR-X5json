     ,"INC-SPECT":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The total 4pi neutron yields of each shot were"
		,"1.65*10**18 and 6.60*10**17 (February and March,"
		,"respectively)."]
	}
