     ,"INC-SOURCE":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SPALL", "dict":"INC-SOURCE", "idict":19,"hlp":"Spallation"}]
	,"x4freetext":[" \"White spectrum\" neutron beams were generated"
		,"from an unmoderated tungsten spallation source using"
		,"the 800-MeV proton beam from the LANSCE linear"
		,"accelerator."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":[" Fission fragments were detected by nine pairs of"
		,"1-cm2 Si p-i-n diode detectors (Hamamatsu S3590-09)"
		,"positioned 3.5 cm from the target."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"TOF", "dict":"METHOD", "idict":21,"hlp":"Time-of-flight"}]
	,"x4freetext":[" The time of flight of each interacting neutron"
		,"was measured using a timing pulse from a Si p-i-n"
		,"diode and the accelerator rf signal. The distance"
		,"from the spallation target to the Pu targets was"
		,"measured to be 1384.9 +- 1.1 cm. The solid angle"
		,"covered by the Si p-i-n diodes was ~11% of 2pi."]
	}
      ]
     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The 2E method was used to measure the fission product"
		,"masses and their TKE by detecting the fission"
		,"products and determining their energies after neutron"
		,"emission."]
	}
      ]
     ,"CORRECTION":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Corrections for PHD, the pulse-height defect, and"
		,"energy loss of fragments in the target and backing"
		,"foils are also applied."]
	}
