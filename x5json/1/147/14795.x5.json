     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":{"Nucl":"94-PU-240","ENR":0.99874}
	,"x4freetext":[" The plutonium targets were"
		,"prepared by vapor deposition using the method. The"
		,"targets consisted of 2-cm-diameter circular deposits"
		,"of the Pu isotope on a thin C backing. The target"
		,"thickness was 72.3 microg/cm2 (240Pu) (as measured by"
		,"alpha spectroscopy). The source material for the"
		,"240Pu target was 99.874 wt% 240Pu. The assumed"
		,"chemical composition of the targets was that of PuF4."
		,"The C backing thickness was 100 microg/cm2. The"
		,"targets were at an angle of 45 degree with respect to"
		,"the incident beam."]
	}
      ]
