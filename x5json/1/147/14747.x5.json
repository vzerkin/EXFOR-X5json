	{"x4pointer":" "
	 ,"x4code":{"header":"ERR-T"
	     ,"headerHelp":"Total uncertainty (1-Sigma)"}
	,"x4freetext":[" All errors are reported at the one-sigma"
		,"limit. The statistical and systematic uncertainties"
		,"were propagated."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-SYS", "min":"1.", "max":"2."
	     ,"headerHelp":"Total systematic uncertainty"}
	,"x4freetext":[" The systematic uncertainty of 1%-2%,"
		,"from the uncertainties of the decay rates of the"
		,"radionuclides in the sources used in the calibration"
		,"of the detectors, does not apply to the reported"
		,"ratios of gamma-ray intensities."]
	}
      ]
