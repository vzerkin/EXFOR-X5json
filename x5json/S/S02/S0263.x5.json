     ,"INC-SOURCE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["A primary beam of 22Ne7+ at 6.0 AMeV bombarded a 1H2"
		," gas target with thickness of 1.15 mg/cm2."
		,"After the separation and purification with the"
		," electric-magnetic system of the separator, a high"
		," quality 22Na secondary beam was delivered with energy"
		," of 78.3+-1.0 MeV, intensity of about 2.5E5 s-l and"
		," purity better than 90%."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The 4He gas target was maintained within 53.33+-0.53"
		," kPa by a gas-flow system."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":[" Three ST (silicon-detector telescope) at"
		," different deg. The ST1 was located at the 0 deg"
		," direction."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"PPAC", "dict":"DETECTOR", "idict":22,"hlp":"Parallel plate avalanche counter"}
	    ,{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":[" A parallel plate avalanche counter and a"
		," single-pad silicon detector to monitor the beam spot"
		," size, location distribution and energy of the"
		," secondary beam."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}]
	,"x4freetext":[" Particle identification achieved by a dE-E"
		," silicon detector telescope. The dE detector is a"
		," double-sided silicon strip detector. The E detector"
		," is a single-pad silicon detector."]
	}
      ]
