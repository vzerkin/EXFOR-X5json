     ,"INC-SOURCE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The secondary 13B and 13O radioactive beams were"
		," produced by fragmentation of a primary 59.54 MeV/u"
		," 16O8+ beam on a production 9Be target. The average"
		," intensities of 13B and 13O beams were approximately"
		," 1500 and 200 pps, with purities of 53% and 2%,"
		," respectively."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["A 12.24-mg/cm2-thick self-supporting 208Pb target"]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"SISD", "dict":"DETECTOR", "idict":22,"hlp":"Silicon strip detector"}
	    ,{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":[" Two double-sided silicon strip"
		," detectors (DSSDs), 87 um and 65 um thick, both"
		," segmented into 16 horizontal and vertical strips"
		," (3-mm width on each side), were used to provide"
		," precise position and direction of the incident beam"
		," particles, on an event-by-event basis."
		,"The elastically scattered and reaction products were"
		," detected by an array of four silicon telescopes,"
		," mounted 267 mm away from the lead target. The"
		," telescopes covered an angular range from 3-27 degree"
		," in the laboratory fame, with a resolution of about"
		," 0.4 degree. Each telescope consisted of a DSSD"
		," (32x32 pixels, 64x64 mm2) with dE detector"
		," approximately 150 um thick backed by a silicon E"
		," detector approximately 1500 um thick, which measured"
		," the residual energy of the particles. To ensure a"
		," satisfactory performance, the temperature of this"
		," detector array was kept at -20 degree centigrade"
		," during the whole experiment, using an alcohol"
		," circulating system."]
	}
      ]
