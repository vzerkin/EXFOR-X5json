     ,"INC-SOURCE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["9Be(16O,13C) and 9Be(16O,14C). The secondary beams"
		," were produced using a primary 16O beam at 59.5 MeV/u"
		," from the HIRFL impinged on a 9Be target with 2.0-mm-"
		," thick. The secondary beams of interest were selected"
		," and optimized by adjusting the magnetic rigidity."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The thicknesses of the 208Pb targets were 13.30 mg/cm2"
		," for the 14C beam at 294 MeV and 12.24 mg/cm2 for the"
		," 13C beam at 340 MeV and the 14C beam at 342 MeV."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":[" Two double-sided silicon detectors (DSSDs),"
		," 87 um and 65 um thick, respectively, were used to"
		," provide the accurate location and orientation of the"
		," incident particles with respect to the target"
		," alignment. Both DSSDs have 16 junction and 16 ohmic"
		," strips, 3 mm wide. They were placed 669 mm and 69 mm"
		," upstream of the 208Pb target."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}]
	,"x4freetext":[" To detect the scattering particles, four dE-E"
		," telescopes were installed 267 mm downstream of the"
		," target, covering an angular range from about 3-27 deg"
		," in the laboratory reference."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}]
	,"x4freetext":[" The scattering particles were identified and"
		," selected using the two-dimensional dE-E spectra"
		," obtained with the telescopes."]
	}
      ]
