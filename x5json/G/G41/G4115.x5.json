     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The targets were made from metal foils of structural"
		,"steels of known elemental composition. These foils"
		,"were rectangular strips 1 x 1 x 0.01 cm in size and"
		,"about 0.048 g in weight and contained Fe - 66.2%, Cr"
		,"- 16.9%, Ni - 9.9%, O - 3.2%, Mn - 1.66%, Si - 0.7%,"
		,"Ti - 0.57%, Co - 0.29%, Cu - 0.16%."]
	}
