	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["By authors:"
		," The Cd cover absorbed thermal neutrons was not"
		,"sufficient to measure the resonance integral"
		,"accurately because the 186 W has a resonance peak"
		,"around 18.83 eV which overlaps with the 113Cd"
		,"resonance peak (18.4 eV), namely epithermal neutrons"
		,"around 18.4 eV was absorbed strongly by the Cd-filter"
		,"rather than by the 186W."]
	}
