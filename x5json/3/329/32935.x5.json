     ,"INC-SOURCE":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"D-T", "dict":"INC-SOURCE", "idict":19,"hlp":"3H(d,n)"}]
	,"x4freetext":[" The neutron yield is approximately (3-5)E10 n/s."
		," The neutrons were produced by a T(d,n)4He reaction"
		," with a D+ beam current of 250 uA. The thickness of"
		," the solid tritium-titanium (T-Ti) target used in the"
		," generator was 2.5 mg/cm2, and the energy of the"
		," incident D+ beam was 300 keV."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["High-purity aluminum (0.5 mm, 99.999% purity) foil"
		," was sandwiched between natural zirconium (0.1 mm,"
		," 99.5% purity) and niobium (0.1 mm, 99.95% purity)"
		," foils. Four round disk samples with a diameter of 20"
		," mm were placed approximately 5.0 cm away from the"
		," T-Ti target relative to the deuteron beam incident"
		," angles of 0, 30, 60, and 100 deg. One arc shape"
		," sample with 0.5 cm in width and about 4 cm in length"
		," was placed about 3.0 cm away from the T-Ti target and"
		," about 60 to 135 deg relative to the deuterium ion"
		," incident direction."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SIBAR", "dict":"DETECTOR", "idict":22,"hlp":"Silicon surface barrier detector"}]
	,"x4freetext":[" An Au-Si surface barrier detector for the"
		," detection of accompanying particles."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"HPGE", "dict":"DETECTOR", "idict":22,"hlp":"Hyperpure (high purity) germanium detector"}]
	,"x4freetext":[" The activities of those Nb and Zr samples were"
		," determined using an HPGe gamma-ray detector with a"
		," relative efficiency of 68% and an energy resolution"
		," of 1.82 keV FWHM at 1.33 MeV."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"SPEC", "dict":"DETECTOR", "idict":22,"hlp":"Large spectrometer system"}]
	,"x4freetext":[" A dedicated accelerator mass spectrometer, the"
		," GYIG 1 MV AMS instrument was used to measure 26Al."]
	}
      ]
