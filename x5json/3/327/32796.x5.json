	  ,"Radiations":[{"Type":"DG", "Energy":[934.44], "Intensity":0.9915}]}
	}
      ]
     ,"INC-SOURCE":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"D-T", "dict":"INC-SOURCE", "idict":19,"hlp":"3H(d,n)"}]
	,"x4freetext":[" The neutrons were produced with a yield of"
		,"approximately 3 to 4E10 n/(4pis). The deuteron ion"
		,"beam current was 180 uA with of an energy of 250 keV."
		,"The solid tritium-titanium (T-Ti) target used in the"
		,"generator was approximately 2.59 mg/cm2 thick."]
	}
      ]
     ,"CORRECTION":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The correction includes self-absorption correction,"
		,"cascade coincidence correction, and geometric"
		,"correction, respectively."]
	}
      ]
