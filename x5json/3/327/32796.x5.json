     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The cesium iodide (CsI) powder of natural isotopic"
		,"composition (purity 99.99%) was pressed into a"
		,"pellet, approximately 20.0 mm in diameter, and 1.5 mm"
		,"in thickness."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"HPGE", "dict":"DETECTOR", "idict":22,"hlp":"Hyperpure (high purity) germanium detector"}]
	,"x4freetext":[" A lead-shielded HPGe detector (ORTEC, USA)."
		,"The efficiency of the detector was calibrated using"
		,"152Eu standard sources. The relative efficiency of"
		,"the detector was 68% compared to the NaI detector,"
		,"and the energy resolution was 1.82 keV (FWHM) at 1.33"
		,"MeV of 60Co."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}]
	,"x4freetext":[" Irradiation was lasted approximately 17 h."
		,"Three groups of samples were placed at 35, 75, and"
		,"112 deg relative to the deuteron beam direction and"
		,"centered around the T-Ti target at a distance of"
		,"approximately 4.5 cm."]
	}
      ]
     ,"MONITOR":[
	{"x4pointer":" "
	 ,"x4code":{"code":"41-NB-93(N,2N)41-NB-92-M,,SIG"
		,"reaction":"41-NB-93(N,2N)41-NB-92-M,,SIG"}
	}
      ]
