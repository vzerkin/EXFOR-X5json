     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"BGO", "dict":"DETECTOR", "idict":22,"hlp":"Bismuth-Germanate crystal detector"}]
	,"x4freetext":[" The GALILEO array, with 25 Compton-suppressed"
		,"HPGe detectors, was used to measure gamma-transitions"
		,"from fusion-evaporation residues. The detectors are"
		,"arranged in four rings at 152, 129, 119, and 90"
		,"degrees to the beam direction."
		,"Each backward ring has five detectors; the 90 degree"
		,"ring has ten detectors. Efficiency is 1.83% at 1408 keV"
		,"with 0.20% resolution (FWHM = 2.88 keV)."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}]
	,"x4freetext":[" The EUCLIDES array, with 40 silicon"
		,"detectors employed for identifies light-charged"
		,"particles. The delta E and E layers are 130 um and"
		,"1000 um thick, with a 62 mm distance to the target."]
	}
