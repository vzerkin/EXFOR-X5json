	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Four stacks have been arranged in two different setups,"
		,"with each stack consisting of four targets made from"
		,"natCr."
		,"The Ti(99.6% pure, 8.1 mg/cm2), Al (99.99% pure,"
		," 4.3 mg/cm2 and 13.4 mg/cm2) and Ir (99.9% pure,"
		,"  55.9 mg/cm2 and 56.9 mg/cm2)."
		,"The Cr targets were measured individually, obtaining a"
		,"mass thickness in the range 10.5-17.0 mg/cm2"]
	}
