     ,"DETECTOR":[
	{"x4pointer":" "
	,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"SIBAR", "dict":"DETECTOR", "idict":22,"hlp":"Silicon surface barrier detector"}]
	,"x4freetext":[".The experiments were performed using"
		,"conventional delta-E-E surface barrier detector"
		,"techniques. Two or three telescopes were used during"
		,"the various experiments. The thicknesses of the delta-E"
		,"and E detectors were 100-200 mum and 1000-2000 mum,"
		,"respectively."]
	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"GELI", "dict":"DETECTOR", "idict":22,"hlp":"Germanium-Lithium detector"}]
	,"x4freetext":[".A Ge(Li) monitor detector was essential in"
		,"determining the relative cross sections(by the counting"
		,"rate of the deuterons elastically scattered of the"
		,"target atoms."]
	}
      ]
     ,"COMMENT":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["*By authors*.The absolute cross section scale was"
		,"determined by the charge integration in the Faraday"
		,"cup and the effective target thickness determined at"
		,"the beginning of the experiment. Because of the"
		,"inaccuracy of this procedure the reaction products were"
		,"measured at least twice at each angle by exposing the"
		,"target to different integrated charges."]
	}
      ]
     ,"INC-SOURCE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["*EN-RSL-FW*.An overall energy resolution of 350 keV"
		," (FWHM) was typical for the Li-6 spectra."]
	}
      ]
     ,"ADD-RES":[
	{"x4pointer":" "
	,"x4codes":[{"code":"COMP", "dict":"ADD-RES", "idict":20,"hlp":"Comparison with calculated values"}]
	,"x4freetext":[".DWBA calculations, the alpha spectroscopic"
		," factors."
		," Typical energy spectra of Li-6 on S-32 and S-34 was"
		,"represent on fig.1 and fig.2"]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["A gas cell filled with H(2)S-32 or with H(2)S-34 was"
		,"used as target, the isotopical enrichment was 95%"
		,"and 91.2%, respectively."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}]
	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"BCINT", "dict":"METHOD", "idict":21,"hlp":"Beam current integrated"}]
	,"x4freetext":[".The beam intensity ranged from 20 nA to 1 muA"
		,"on the target, depending on the reaction angle."]
	}
      ]
