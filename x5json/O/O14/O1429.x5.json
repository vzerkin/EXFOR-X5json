	,"x4freetext":[" 20 UD accelerator."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	,"x4codes":[{"code":"EXTB", "dict":"METHOD", "idict":21,"hlp":"Irradiation with external beam"}]
	,"x4freetext":[" Typical beam currents were below 50 nA."]
	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"SITA", "dict":"METHOD", "idict":21,"hlp":"Single target irradiation"}]
