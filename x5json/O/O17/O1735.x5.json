     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["Polyethylene (CH2)n target was used with a scattering"
		,"angle greater than 90 degree. At small angles self-"
		,"supporting graphite foils of about 60 mum and 10 mum"
		,"have been used. The 60 mum target was made on a lathe"
		,"by turning a vacuum-sucked piece of pure graphite."
		,"The 10 mum target was obtained by using a sputtering"
		,"technique whereby a carbon-arc was drawn in vacuum"
		,"under a horizontal glass plate covered with a dried"
		,"soapfilm. The number of carbon atoms per cm**2 of the"
		," (CH2)n target was determined by weighing. For other"
		,"targets this was done by comparison of yield"
		,"measurements with measurements done the (CH2)n target."]
	}
      ]
     ,"FACILITY":[
	{"x4pointer":" "
	,"x4codes":[{"code":"SYNCY", "dict":"FACILITY", "idict":18,"hlp":"Synchro cyclotron"}
	    ,{"code":"2NEDIKO", "dict":"INSTITUTE", "idict":3,"hlp":"Nat`l Inst. for Nucl. and High Energy Physics, Sect.K, Netherlands"}]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}]
	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"BCINT", "dict":"METHOD", "idict":21,"hlp":"Beam current integrated"}]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"CSICR", "dict":"DETECTOR", "idict":22,"hlp":"Cesium-Iodide crystal"}
	    ,{"code":"NAICR", "dict":"DETECTOR", "idict":22,"hlp":"Sodium-Iodide crystal"}]
	,"x4freetext":[" The detector consisted of a 0.2 mm"
		,"thick CsI(Tl) crystal and a 6 mm  thick NaI(Tl)"
		,"scintillation counter."]
	}
	,{"x4pointer":" "
	,"x4codes":[{"code":"SOLST", "dict":"DETECTOR", "idict":22,"hlp":"Solid-state detector"}]
	,"x4freetext":[".The solid state detector was a p-i-n type"
		,"lithium-drifted silicon counter of 2.2 mm thickness,"
		,"in which a proton could dissipate an energy of"
		,"approximately 20 MeV as a maximum."]
	}
      ]
     ,"CORRECTION":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":[" The dead-time correction was made."]
	}
      ]
     ,"ERR-ANALYS":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":[" The systematic errors in the absolute values of the"
		," differential cross section is about 6%. This error"
		,"is mainly due to uncertainty in the target thickness"
		,"determination and the error in the charge measurement."
		,"Errors due to finite geometry and multiple scattering"
		,"were estimated to be small compared to the other"
		,"uncertainties."]
	}
	,{"x4pointer":" "
	,"x4code":{"header":"DATA-ERR"
	     ,"headerHelp":"Error in value of quantity, defined under ERR-ANALYS"}
	,"x4freetext":[".The errors bars indicated in the graphs are"
		,"composed of statistical errors and interpretational"
		,"errors added linearly."]
	}
	,{"x4pointer":" "
	,"x4code":{"header":"ERR-S", "min":"1.", "max":"10."
	     ,"headerHelp":"Statistical uncertainty (1-Sigma)"}
	,"x4freetext":[".Statistical error varied from approx. 1%"
		," to 10% in poor case."]
	}
	,{"x4pointer":" "
	,"x4code":{"header":"EN-ERR"
	     ,"headerHelp":"Uncertainty in incident projectile energy"}
	,"x4freetext":[".The energy of the deuteron beam."]
	}
