     ,"SAMPLE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["The target Fe54(2)O(3) enriched to 92% with an"
		,"admixture of 8% Fe-56. the thickness of the target was"
		," 250 mug/cm**2 corresponding to an energy loss of"
		," 15 keV for the 5.8 MeV deuteron beam."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	,"x4codes":[{"code":"TOF", "dict":"METHOD", "idict":21,"hlp":"Time-of-flight"}]
	}
      ]
     ,"FACILITY":[
