	,"x4code":{"header":"ERR-T"
	     ,"headerHelp":"Total uncertainty (1-Sigma)"}
	,"x4freetext":[".The overall uncertainty associated with each"
		,"experimental point varied from 10% to 17%, depending"
		,"on the number of counts in the elastic peak at each"
		,"angle."]
	}
	,{"x4pointer":" "
