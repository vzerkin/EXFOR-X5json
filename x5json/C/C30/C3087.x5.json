     ,"INC-SPECT":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The secondary 8B beam was produced in-flight, as part"
		,"of a cocktail beam together with 7Be and 7Li. The"
		,"reaction used was 3He+6Li with the two proton"
		,"transfer channel 3He(6Li,n)8B, leading to 8B. A"
		,"primary bunched beam of 6Li was accelerated at 37 MeV"
		,"by the UND FN tandem, and impinged on a 2.5 cm long"
		,"gas target of 3He at a pressure of 850 Torr. In the"
		,"middle of the target, the beam energies corresponded"
		,"to 26.5 MeV, 19.2 MeV, and 14.3 MeV for 8B, 7Be,"
		,"and 7Li, respectively."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SISD", "dict":"DETECTOR", "idict":22,"hlp":"Silicon strip detector"}
	    ,{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}]
	,"x4freetext":[" The reaction products, including"
		,"elastically scattered particles, were detected in"
		,"four two-stage dE-E telescopes. Each of these"
		,"consisted of a double-sided silicon strip detector"
		," (DSSSD) and a pad silicon detector."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["A natZr target of 1.95 mg/cm2 thickness."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}
	    ,{"code":"TOF", "dict":"METHOD", "idict":21,"hlp":"Time-of-flight"}]
	,"x4freetext":[" The elastically scattered 8B nuclei were"
		,"very well separated from the other beam products with"
		,"the dE-E technique. For the breakup measurement, an"
		,"unambiguous separation has to be obtained between the"
		,"7Be fragments resulting from 8B breakup and the 7Be"
		,"contamination in the secondary beam, elastically"
		,"scattered by the natZr target. This was achieved for"
		,"a very small part of the data with a time-of-flight"]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"TOF", "dict":"METHOD", "idict":21,"hlp":"Time-of-flight"}]
	,"x4freetext":[" technique which was imposed between the start"
		,"of the DSSSD detectors and the radio frequency of the"
		,"pulsed beam. For the rest of the data the separation"
		,"was obtained by energy. For that energy thresholds"
		,"for a pure 7Be fragment detection were obtained,"
		,"through comparison of energy distributions of the"
		,"elastic scattered 7Be secondary beam and of the 7Be"
		,"fragments, the last obtained in a CDCC calculation."
		,"Finally recovery ratios were applied for the missing"
		,"events."]
	}
      ]
