     ,"ADD-RES":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["CDCC calculations have been performed assuming a"
		,"three-body model for the reaction (7Be+p+90Zr). It"
		,"should be noted that a natural target was employed;"
		,"however, authors may anticipate that this does not"
		,"impact the conclusions, as we do not expect a"
		,"significant dependence of the breakup on the specific"
		,"isotope."]
	}
      ]
