     ,"ERR-ANALYS":[
	{"x4pointer":" "
	 ,"x4code":{"header":"ERR-T"
	     ,"headerHelp":"Total uncertainty (1-Sigma)"}
	,"x4freetext":[" Experimental uncertainty, it was assumed"
		,"to be Gaussian. The uncertainty associated with the"
		,"ratio Y/e (Yield/efficiency=Total number of"
		,"reactions) was largely dominated by the statistical"
		,"uncertainty of the background subtraction. The"
		,"overall uncertainties for Y/e were ~24% and ~74% for"
		,"the 3.7 and 3.1 MeV/nucleon laboratory system beam"
		,"energies, respectively."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-S"
	     ,"headerHelp":"Statistical uncertainty (1-Sigma)"}
	,"x4freetext":[" For the measurement with beam energy of 3.7"
		,"MeV/nucleon->2.95 c.m., the statistical uncertainty"
		,"was ~18%. Unfortunately, the second measurement, with"
		,"beam energy of 3.1 MeV/nucleon-> 2.35 c.m., suffered"
		,"from very low statistics, and the associated"
		,"uncertainty was ~72%."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-1"
	     ,"headerHelp":"1st partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" ~6% uncertainty introduced from the"
		,"normalization method of the empty cell data."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-2"
	     ,"headerHelp":"2nd partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" ~13% uncertainty from the different"
		,"statistical model inputs used in RAINIER code."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-3"
	     ,"headerHelp":"3rd partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" The target areal density uncertainty of ~5%."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-4"
	     ,"headerHelp":"4th partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" The number of projectiles introduced an ~8%"
		,"uncertainty to the total incident particles."]
	}
