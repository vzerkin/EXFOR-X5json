	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The inclusive two-neutron removal cross section for"
		,"the formation of 36Ca was determined from the"
		,"efficiency corrected number of 36Ca residues detected"
		,"in the S800 focal plane, the number of incident 38Ca"
		,"projectiles, and the areal density of the target."]
	}
