     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"COINC", "dict":"METHOD", "idict":21,"hlp":"Coincidence"}]
	,"x4freetext":[" Employing particle-gamma coincidences, the"
		,"exclusive cross sections to the 0+ and 2+1 states are"
		,"obtained. Lacking a gamma-ray detectable in GRETINA,"
		,"exclusive cross sections to the 0+1 and 0+2 states"
		,"are indistinguishable. In the following, their summed"
		,"cross section is denoted sigma(0+) = sigma(0+1) +"
		,"sigma(0+2)."]
	}
      ]
     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Exclusive 2+1 cross section was subtracted from the"
		,"inclusive cross section to obtain 0+ value."]
	}
      ]
