     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"CHSEP", "dict":"METHOD", "idict":21,"hlp":"Chemical separation of products"}
	    ,{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}
	    ,{"code":"STTA", "dict":"METHOD", "idict":21,"hlp":"Stacked target irradiation"}]
	,"x4freetext":[" Stacks of targets at the center of"
		,"a scattering chamber were bombarded normally with"
		,"deuterons. After each bombardment, the targets in the"
		,"stack were subjected to radiochemical separations."
		,"The resultant samples of reaction-product nuclides,"
		,"mounted as circular precipitates of known area under"
		,"mylar coverings, were then counted absolutely."]
	}
      ]
