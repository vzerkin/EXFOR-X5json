   ,"ref":"Jour: Applied Radiation and Isotopes, Vol.212, p.111469 (2024)"
   ,"title":"Cross section measurements for the production of 49, 51Cr and 47Sc from proton irradiation of natural vanadium up to 24 MeV"
   ,"x4subents":[
   {"SUBENT":"C3084001", "isub":1, "compiled":20250825, "TransID":"C252", "TransDate":20260112
    ,"BIB":{
      "TITLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Cross section measurements for the production of 49,"
		,"51Cr and 47Sc from proton irradiation of natural"
		,"vanadium up to 24 MeV"]
	}
      ]
     ,"AUTHOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"name":"S.J.Cingoranelli","ini":"S.J.","nam":"Cingoranelli"}
	    ,{"name":"L.Burnett","ini":"L.","nam":"Burnett"}
