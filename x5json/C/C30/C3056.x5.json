     ,"INC-SPECT":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["A 17O beam with an intensity of 10**4 ions/s was"
		,"produced from natural abundance of oxygen (0.038% 17O)."
		," The horizontal error bars of 300 keV correspond to"
		,"the spatial localization of the fusion event on a"
		,"single anode."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"IOCH", "dict":"DETECTOR", "idict":22,"hlp":"Ionization chamber"}]
	,"x4freetext":[" A MuSIC detector is a simple, active thick-"
		,"target detector. It consists of a transverse-field,"
		,"Frisch-gridded ionization chamber with the anode"
		,"subdivided into strips transverse to the beam"
		,"direction."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The CH4 gas in MuSIC@Indiana, at a pressure of 150"
		,"torr (99.999% purity), served as both target and"
		,"detection medium."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The beam, accelerated to energies of Elab = 55, 48,"
		,"47.5, and 47 MeV, impinged on MuSIC@Indiana. At the"
		,"incident energies measured, fusion of the incident"
		,"beam with 12C nuclei produces 29Si with an excitation"
		,"energy E* = 40-44 MeV. This compound nucleus"
		,"deexcites by emission of neutrons, protons, and alpha"
		,"particles to produce an evaporation residue."]
	}
      ]
