     ,"CORRECTION":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The yields from the 13C target were corrected for"
		,"neutron background, with an uncertainty assumed to be"
		,"half of the correction. A 1% reproducibility"
		,"uncertainty, and the background uncertainty for"
		,"Ealpha > 6 MeV. The relative efficiency corrections"
		,"were typically ~10%, but were as large as 27% in some"
		,"cases."]
	}
      ]
