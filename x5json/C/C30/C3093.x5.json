     ,"INC-SPECT":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The radioactive 12N beam was produced from the"
		,"3He(10B,12N) n reaction. Due to the similarity in"
		,"magnetic rigidity, the secondary beam was composed of"
		,"12N7+(44%) and 7Be4+(56%) ions. The average rate"
		,"of 12N during the experimental runs was about 10**3"
		,"pps. The energies of the 12N and 7Be beams, after the"
		,"scintillator detector and before hitting the 197Au"
		,"target, were 73.3 MeV and 42.0 MeV, respectively."]
	}
      ]
     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SISD", "dict":"DETECTOR", "idict":22,"hlp":"Silicon strip detector"}]
	,"x4freetext":[" The detection system consisted of three 500-"
		,"microm-thick double-sided silicon strip detectors"
		," (DSSSD) with front and back sides segmented in 128"
		,"strips."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["A 4.7-mg/cm2-thick 197Au film was mounted on a target"
		,"holder set at ~30 degree relative to the secondary"
		,"beam axis. The energy loss of the 12N through the"
		,"197Au target is about 6.5 MeV."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The produced 12N particles were selected by the"
		,"momentum achromatic recoil spectrometer (MARS). The"
		,"intensity of the beam was monitored by a scintillator"
		,"detector positioned downstream of the MARS beam line."
		,"The elastically scattered 12N and 7Be particles are"
		,"clearly distinguished in the energy spectra at forward"
		,"angles. The yield of 7Be is very faint at backward"
		,"angles due to the lower cross section compared to the"
		,"yield of 12N."]
	}
      ]
     ,"CORRECTION":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Estimates from the Monte Carlo simulation were"
		,"employed to correct the measured yields and obtain"
		,"the elastic cross section."]
	}
      ]
