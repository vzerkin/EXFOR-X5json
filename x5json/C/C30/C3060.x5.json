     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"MAGSP", "dict":"DETECTOR", "idict":22,"hlp":"Magnetic spectrometer"}]
	,"x4freetext":[" The Super-Enge Split-Pole Spectrograph."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"TELES", "dict":"DETECTOR", "idict":22,"hlp":"Counter telescope"}
	    ,{"code":"SISD", "dict":"DETECTOR", "idict":22,"hlp":"Silicon strip detector"}
