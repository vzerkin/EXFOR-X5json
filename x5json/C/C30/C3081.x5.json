	 ,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}]
	,"x4freetext":[" The elastically scattered 8B nuclei were very"
		,"well separated from the other beam products with the"
		,"dE-E technique."]
	}
