     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}]
	,"x4freetext":[" All activations were conducted using ion-"
		,"beams. An electro-static analyzer and a bending"
		,"magnet on the low energy side facilitated the"
		,"selection of the ion beam to be accelerated. On the"
		,"high-energy side, an analyzing magnet allowed for the"
		,"selection of the charge state,and thus beam energy."
		,"Targets were placed in vacuum at the end of the"
		,"electrically-isolated +15 degrees beamline. Electrons"
		,"ejected from the target were suppressed both"
		,"geometrically and magnetically with two permanent"
		,"magnets near the target."]
	}
      ]
     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"DECAY", "dict":"ANALYSIS", "idict":23,"hlp":"Decay curve analysis"}]
	,"x4freetext":[" A system of equations was prepared describing"
		,"gamma emission as a function of activity at end-of-"
		,"bombardment (EOB). This system of equations included"
		,"parent-daughter relationships, decay branching and"
		,"constants, gamma-ray intensities, spectra collection"
		,"time and collection duration. These equations were"
		,"fit to the efficiency-corrected data using a"
		,"Monte-Carlo technique for error estimation purposes."
		,"In this way, decay corrected activities at the EOB were"
		," determined. The activities for each radioisotope"
		,"observed at EOB were then used to calculate"
		,"production rates."]
	}
      ]
     ,"ERR-ANALYS":[
	{"x4pointer":" "
	 ,"x4code":{"header":"DATA-ERR"
	     ,"headerHelp":"Error in value of quantity, defined under ERR-ANALYS"}
	,"x4freetext":[" The cross-section errors were based on the"
		,"uncertainties in target thicknesses, beam current,"
		,"counting statistics (area under curve and background),"
		," and detector efficiency. The detector efficiency"
		,"uncertainties were based on the accuracy of the"
		,"calibration sources, counting statistics, and fits."]
	}
      ]
     ,"CORRECTION":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The efficiency-corrected data using a Monte-Carlo"
		,"technique for error estimation purposes result in"
		,"decay corrected activities."]
	}
