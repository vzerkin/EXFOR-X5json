     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"HPGE", "dict":"DETECTOR", "idict":22,"hlp":"Hyperpure (high purity) germanium detector"}]
	,"x4freetext":[" The radioactivities of the product"
		,"radionuclides were measured non-destructively using a"
		,"high-purity germanium gamma-ray detector."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Fe foils of 25 microm thickness (supplied by"
		,"Goodfellow; chemical purity: 99.0 %) were used as"
		,"target."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"ACTIV", "dict":"METHOD", "idict":21,"hlp":"Activation"}]
	,"x4freetext":[" The activity measurement for each sample was"
		,"repeated by giving sufficient decay interval to check"
		,"the half-lives of the activation products as well as"
		,"to avoid interferences by overlapping gamma-lines"
		,"from undesired products. At 5 cm counting distance,"
		,"the effect of the sample size on the efficiency and"
		,"also the random coincidence loss became almost"
		,"negligible."]
	}
      ]
     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"DECAY", "dict":"ANALYSIS", "idict":23,"hlp":"Decay curve analysis"}]
	,"x4freetext":[" The peak area (counts) under a characteristic"
		,"gamma-ray of a reaction product was converted to"
		,"count rate and then converted to the decay rate by"
		,"applying corrections for gamma-ray intensity and"
		,"efficiency of the detector. The decay rate was"
		,"extrapolated to the end of bombardment (EOB). From"
		,"the decay rate at EOB and the measured deuteron beam"
		,"flux, the cross section for the formation of the"
		,"radioactive product was calculated using the"
		,"well-known activation equations."]
	}
      ]
     ,"ERR-ANALYS":[
	{"x4pointer":" "
	 ,"x4code":{"header":"ERR-T"
	     ,"headerHelp":"Total uncertainty (1-Sigma)"}
	,"x4freetext":[" The combined uncertainty in the cross section"
		,"was estimated from the uncertainties associated with"
		,"measurements: peak area (0.5-7 %), efficiency of the"
		,"detector (4 %), gamma-ray intensities (0.006-1.4 %),"
		,"half-life (0.0001-0.05 %) and deuteron flux (6 %)."
		,"The overall uncertainty of measured cross sections"
		,"amounted to 8-12 % (1 sigma)."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-S", "min":"0.5", "max":"7."
	     ,"headerHelp":"Statistical uncertainty (1-Sigma)"}
	,"x4freetext":[" Peak area."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-1"
	     ,"headerHelp":"1st partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" Detector efficiency."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-2", "min":"0.006", "max":"1.4"
	     ,"headerHelp":"2nd partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" Gamma-ray intensities."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-3", "min":"0.0001", "max":"0.05"
	     ,"headerHelp":"3rd partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" Half-life."]
	}
	,{"x4pointer":" "
	 ,"x4code":{"header":"ERR-4"
	     ,"headerHelp":"4th partial uncertainty, defined under ERR-ANALYS"}
	,"x4freetext":[" Deuteron flux."]
	}
      ]
     ,"CORRECTION":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The correction for the true coincident gamma-ray"
		,"summing was also negligible."]
	}
