     ,"MONITOR":[
	{"x4pointer":" "
	 ,"x4code":{"code":""}
	,"x4freetext":["A NaI monitor counter located at 45 degrees relative"
		,"to the beam was used to detect elastically scattered"
		,"3He and alpha particles and thus to determine"
		,"absolute differential cross sections. The elastic"
		,"scattering cross section was assumed to be equal to"
		,"the Rutherford cross section at 45 degrees for 3He"
		,"and equal to 1.15 times the Rutherford cross section"
		,"for alpha particles, as indicated by optical model"
		,"calculations."]
	}
