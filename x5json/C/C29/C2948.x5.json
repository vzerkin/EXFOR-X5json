     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"SPEC", "dict":"DETECTOR", "idict":22,"hlp":"Large spectrometer system"}
	    ,{"code":"PROPC", "dict":"DETECTOR", "idict":22,"hlp":"Proportional counter"}
	    ,{"code":"SCIN", "dict":"DETECTOR", "idict":22,"hlp":"Scintillation detector"}]
	,"x4freetext":[" Reaction products entered the TUNL"
		,"Enge split-pole magnetic spectrograph whose magnetic"
		,"field was set at B = 0.81 T to focus reaction"
		,"products into the detector`s focal plane. The"
		,"spectrograph was set at six different laboratory"
		,"angles (thetalab = 9, 12, 20, 22, 25, and 27 degrees)"
		,"and its entrance aperture subtended a solid angle"
		,"with respect to the target of 1 msr for all angles. A"
		,"position sensitive ionization chamber backed by a"
		,"scintillator."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The implanted 20Ne transmission targets used in the"
		,"experiment were fabricated using an electron"
		,"cyclotron resonance ion source to implant 20Ne at an"
		,"energy of 25 keV directly into a 40+-4 microg/cm2"
		,"thick carbon foil. The foil was mounted on a"
		,"rectangular glass slide (3.7 cm x 2.5 cm) from which"
		,"a total of four targets were obtained. Based on"
		,"analysis using the software package SIMNRA, the"
		,"targets were determined to consist of carbon, with a"
		,"3.6+-0.4 microg/cm2 thick region of 20Ne, located"
		,"close to the center, and a relatively thin 0.22+-0.02"
		,"microg/cm2 thick 16O contamination layer located"
		,"at the front."]
	}
      ]
