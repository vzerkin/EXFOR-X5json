     ,"ANALYSIS":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Angular distributions were used to extract the spin and"
		," parity of 19Ne excited states in the astrophysical"
		,"energy range (6-7 MeV). R-matrix calculations were"
		,"performed to investigate the impact of our"
		,"spin-parity assignments on these effects."]
	}
      ]
     ,"ERR-ANALYS":[
	{"x4pointer":" "
	 ,"x4code":{"header":"DATA-ERR"
	     ,"headerHelp":"Error in value of quantity, defined under ERR-ANALYS"}
	,"x4freetext":[" The uncertainties in the differential cross"
		,"sections were obtained by error propagation, adding"
		,"in quadrature the uncertainties in the counts"
		," (yields) and in the target thickness since they are"
		,"mutually independent. The uncertainty in the Jacobian"
		,"of the laboratory to center of mass conversion for"
		,"the cross sections was not considered since its"
		,"inclusion did not have a significant contribution to"
		,"the uncertainties. The uncertainties in the"
		,"laboratory yields come from the fits done using the"
		,"BayeSpec code."]
	}
      ]
