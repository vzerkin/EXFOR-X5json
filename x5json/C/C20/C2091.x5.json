     ,"INC-SOURCE":[
	{"x4pointer":" "
	,"x4code":null
	,"x4freetext":["The 6He+ beam was produced by impinging a 500 MeV, 75"
		,"mu-A proton beam upon a 20.63 g/cm2 ZrC target, and"
		,"extracted using a forced electron beam induced arc"
		,"discharge ion source. The 12.24 keV 6He beam was"
		,"postaccelerated through the ISAC-I (where the beam"
		,"was also stripped to 2+) and ISAC-II accelerators."]
	}
