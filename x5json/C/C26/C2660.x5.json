	 ,"x4codes":[{"code":"MAGSP", "dict":"DETECTOR", "idict":22,"hlp":"Magnetic spectrometer"}]
	,"x4freetext":[" Recoil ions were analyzed in EMMA recoil"
		,"mass spectrometer. Suppression of 50 000 was"
		,"achieved to reduce radioactive beam induced"
		,"background"]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"HPGE", "dict":"DETECTOR", "idict":22,"hlp":"Hyperpure (high purity) germanium detector"}
	    ,{"code":"PPAC", "dict":"DETECTOR", "idict":22,"hlp":"Parallel plate avalanche counter"}
	    ,{"code":"SI", "dict":"DETECTOR", "idict":22,"hlp":"Silicon detector"}
	    ,{"code":"IOCH", "dict":"DETECTOR", "idict":22,"hlp":"Ionization chamber"}]
	,"x4freetext":[" 12 Compton-suppressed HPGe"
		,"detectors of the TIGRESS array. Parallel grid"
		,"avalanche counter and a transmission ionization"
		,"chamber before stopping in a 3000 mm2, 500 microm thick"
		," ion-implanted Si detector."]
	}
      ]
     ,"METHOD":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"EDE", "dict":"METHOD", "idict":21,"hlp":"Particle identification by `E/Delta E` measurement"}
	    ,{"code":"COINC", "dict":"METHOD", "idict":21,"hlp":"Coincidence"}]
	,"x4freetext":[" Prompt gamma rays were detected with the"
		,"TIGRESS array, while the radiative capture products"
		,"85Rb and 84Sr were transmitted to the focal plane of"
		,"the EMMA recoil mass spectrometer in either the 25+"
		,"or 26+ charge state. The recoils of these radiative"
		,"capture reactions were strongly forward focused, with"
		,"a maximum recoil angle of 0.1 degree due to the"
		,"inverse kinematics."]
	}
      ]
