	 ,"x4codes":[{"code":"MAGSP", "dict":"DETECTOR", "idict":22,"hlp":"Magnetic spectrometer"}]
	,"x4freetext":[" Gas-filled separator (DGFRS-2) was used."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"MWPC", "dict":"DETECTOR", "idict":22,"hlp":"Multi-wire proportional counter"}
	    ,{"code":"SISD", "dict":"DETECTOR", "idict":22,"hlp":"Silicon strip detector"}]
	,"x4freetext":[" The nuclei recoiling out from the target"
		,"pass through hydrogen at a pressure of 0.9 mbar"
		,"inside DGFRS-2, 0.7-micron Mylar separating foil, two"
		,"multiwire proportional chambers located in pentane at"
		,"a pressure of 1.6 mbar, and are implanted into"
		,"detectors. The focal detector consisted of two"
		,"48x128-mm2 double-sided strip detectors with 48 1-mm"
		,"horizontal strips on the front side and 128 1-mm-wide"
		,"vertical strips on the back one. The first detector"
		,"shielded a part of the rear detector. The back strips"
		,"were paired together to form 110 strips of 2 mm in"
		,"width. This detector was surrounded by eight"
		,"60x120-mm2 side strip detectors, each with eight"
		,"strips, constituting a box with a depth of 120 mm."]
	}
      ]
