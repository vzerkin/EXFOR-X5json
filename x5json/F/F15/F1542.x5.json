     ,"DETECTOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"code":"MAGSP", "dict":"DETECTOR", "idict":22,"hlp":"Magnetic spectrometer"}]
	,"x4freetext":[" Gas-filled separator (DGFRS-2) was used."]
	}
	,{"x4pointer":" "
	 ,"x4codes":[{"code":"MWPC", "dict":"DETECTOR", "idict":22,"hlp":"Multi-wire proportional counter"}
	    ,{"code":"SISD", "dict":"DETECTOR", "idict":22,"hlp":"Silicon strip detector"}]
	,"x4freetext":[" DGFRS-2 was filled with hydrogen at a"
		,"pressure of 0.9 Torr. A detector chamber was"
		,"separated from the DGFRS-2 volume by a 0.7-micron"
		,"Mylar foil and filled with pentane at a pressure of"
		,"1.6 mbar. Pentane was a working gas for two multiwire"
		,"proportional chambers (MWPCs) installed in front of"
		,"the detector array to register particles arriving"
		,"from the separator. The focal-plane detector array of"
		,"48 mm in vertical and 220 mm in horizontal directions"
		,"consisted of two 48x128 mm2 double-sided strip"
		,"detectors, with 48 1-mm horizontal strips on the"
		,"front side and 128 1-mm-wide vertical strips on the"
		,"back one. The first detector shielded part of the"
		,"rear detector. The back strips of 1 mm in width were"
		,"paired together to form 110 strips of 2 mm in width."
		,"The focal detector was surrounded by eight 60x120 mm2"
		,"side strip detectors, each with eight strips,"
		,"constituting a box with a depth of 120 mm."]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Rotating target wheels, having six segments with the"
		,"enriched 170Yb and 164Dy targets, were used in the"
		,"experiments. Targets were prepared by electroplating"
		,"onto 0.619+-0.007 mg/cm2 Ti backings."]
	}
