	{"x4pointer":" "
	 ,"x4codes":[{"code":"DECAY", "dict":"ANALYSIS", "idict":23,"hlp":"Decay curve analysis"}]
	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["A titanium layer saturated with deuterium atoms on a"
		,"molybdenum backing was used as a target. The target"
		,"diameter was 11 mm. The mean thickness of the target"
		,"was 1.40+-0.06 mg/cm2 at the deuterium atom"
		,"concentration of 56+-2%. The thickness of the carbon"
		,"build-up on the target surface during the experiment"
		,"was 28 mu-g/cm2."]
	}
      ]
     ,"ADD-RES":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["Comparison with data from TENDL-2023 was performed."]
	}
      ]
