	}
      ]
     ,"SAMPLE":[
	{"x4pointer":" "
	 ,"x4code":null
	,"x4freetext":["The target system consisted of 19 subtargets: 9 gold"
		,"foils interleaved with 10 copper foils which served as"
		,"energy degraders. All subtargets were disk-shaped, with"
		,"12 mm diameter. The thickness of all copper foils was"
		,"24.5 mu-m; the thickness of the gold foils varied from"
		,"19.9 to 26.6 mu-m."]
	}
      ]
