	 ,"x4code":null
	,"x4freetext":["Polarization measurement of fast neutrons from the"
		,"9Be(alpha,n)12C and the 13C(alpha,n)16O reaction using"
		,"a high-pressure 4He-polarimeter in a new design"]
	}
      ]
     ,"AUTHOR":[
	{"x4pointer":" "
	 ,"x4codes":[{"name":"W.Weiss","ini":"W.","nam":"Weiss"}
