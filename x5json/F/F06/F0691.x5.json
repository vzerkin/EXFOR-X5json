	,"x4freetext":[" The 7Be(p,gamma)8B cross section was measured by"
		,"detecting the delayed alpha particles following the"
		,"beta+ decay of 8B."]
	}
      ]
     ,"MONITOR":[
	{"x4pointer":" "
	 ,"x4code":{"code":"(MONIT)3-LI-7(D,P)3-LI-8,,SIG"
		,"heading":"MONIT"
		,"reaction":"3-LI-7(D,P)3-LI-8,,SIG"}
	,"x4freetext":[" The beam energy was"
		,"calibrated to +-0.1% from thick target yield curves"
		,"at resonances in the 19F(p,alpha gammma)16O"
		," [27Al(p,gamma)28Si] reaction at proton energies of"
		,"340.46 keV and 871.11 keV (632.6 keV, 991.8 keV]."
		,"Effective reaction energies were determined from"
		,"measurements of the target thickness and of the"
		,"carbon buildup by consistent Rutherford"
		,"backscattering measurements and (d,p) reaction"
		,"analysis of 12C,16O performed many times during the"
		,"course of the experiment."]
	}
      ]
